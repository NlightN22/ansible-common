#!/bin/sh /etc/rc.common
# Managed by Ansible. Source: roles/openwrt_wireguard/templates/wireguard-endpoint-failover.init.j2

USE_PROCD=1
START=95
STOP=10

name='{{ openwrt_wireguard_failover_instance_name }}'
command_path='{{ openwrt_wireguard_failover_script_path }}'
interval_seconds='{{ openwrt_wireguard_failover_service_interval_seconds | int }}'

start_service() {
  procd_open_instance
  procd_set_param command /bin/sh -c "while true; do \"$command_path\"; sleep \"$interval_seconds\"; done"
  procd_set_param respawn 3600 5 5
  procd_set_param stdout 1
  procd_set_param stderr 1
  procd_close_instance
}

service_triggers() {
  procd_add_reload_trigger network
}
