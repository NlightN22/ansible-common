#!/bin/sh
# Managed by Ansible. Source: ansible_common.core.three_x_ui_openwrt_routing/templates/xp2pc-lan-intercept-failover.sh.j2
set -u

instance_name='{{ openwrt_xp2p_three_x_ui_intercept_failover_instance_name }}'
log_tag="$instance_name"
transport_interface='{{ openwrt_xp2p_three_x_ui_intercept_failover_interface }}'
transport_tag='{{ openwrt_xp2p_three_x_ui_intercept_failover_proxy_outbound_tag }}'
route_table='{{ openwrt_xp2p_three_x_ui_intercept_failover_table }}'
rule_section='{{ openwrt_xp2p_three_x_ui_intercept_failover_rule_section }}'
switch_delay_seconds='{{ openwrt_xp2p_three_x_ui_intercept_failover_switch_delay_seconds | int }}'
restore_switch_delay_seconds='{{ openwrt_xp2p_three_x_ui_intercept_failover_restore_switch_delay_seconds | int }}'
disable_intercept_when_dead='{{ openwrt_xp2p_three_x_ui_intercept_failover_disable_intercept_when_dead | bool | lower }}'
restore_intercept_when_alive='{{ openwrt_xp2p_three_x_ui_intercept_failover_restore_intercept_when_alive | bool | lower }}'
use_socks_smoke='{{ openwrt_xp2p_three_x_ui_intercept_failover_use_socks_smoke | bool | lower }}'
socks_port='{{ openwrt_xp2p_three_x_ui_intercept_failover_socks_port | int }}'

log() {
  logger -t "$log_tag" "$*"
  printf '%s\n' "$*"
}

intercept_disabled() {
  disabled="$(uci -q get "network.${rule_section}.disabled" 2>/dev/null || true)"
  [ "$disabled" = "1" ] || [ "$disabled" = "true" ]
}

route_table_has_default() {
  ip route show table "$route_table" 2>/dev/null |
    grep -E '^default([[:space:]]|$)' |
    grep -F " dev ${transport_interface}" >/dev/null
}

socks_smoke_alive() {
  [ "$use_socks_smoke" = "true" ] || return 0
  curl --socks5-hostname "127.0.0.1:${socks_port}" \
    -fsS --connect-timeout 3 --max-time 5 2ip.me >/dev/null 2>&1
}

transport_alive() {
  ip link show "$transport_interface" >/dev/null 2>&1 || return 1
  route_table_has_default || return 1
  socks_smoke_alive || return 1

  state="$(xp2p client state 2>/dev/null || true)"
  printf '%s\n' "$state" | grep -F "$transport_tag" | grep -Eq '(^|[[:space:]])alive([[:space:]]|$)'
}

transport_dead() {
  ip link show "$transport_interface" >/dev/null 2>&1 || return 0
  route_table_has_default || return 0
  socks_smoke_alive || return 0

  state="$(xp2p client state 2>/dev/null || true)"
  if printf '%s\n' "$state" | grep -F "$transport_tag" | grep -Eq '(^|[[:space:]])dead([[:space:]]|$)'; then
    return 0
  fi

  if ! printf '%s\n' "$state" | grep -F "$transport_tag" | grep -Eq '(^|[[:space:]])alive([[:space:]]|$)'; then
    return 0
  fi

  return 1
}

disable_intercept_rule() {
  if intercept_disabled; then
    log "LAN intercept rule ${rule_section} is already disabled"
    return 0
  fi

  uci set "network.${rule_section}.disabled=1"
  uci commit network
  /etc/init.d/network reload
  log "disabled LAN intercept policy rule ${rule_section}; marked LAN traffic should use the main table"
}

enable_intercept_rule() {
  if ! intercept_disabled; then
    log "LAN intercept rule ${rule_section} is already enabled"
    return 0
  fi

  uci -q delete "network.${rule_section}.disabled" || true
  uci commit network
  /etc/init.d/network reload
  log "enabled LAN intercept policy rule ${rule_section}; marked LAN traffic should use table ${route_table}"
}

if transport_alive; then
  if [ "$restore_intercept_when_alive" != "true" ]; then
    log "transport ${transport_tag} is alive; intercept restore is disabled by model"
    exit 0
  fi

  if intercept_disabled; then
    log "transport ${transport_tag} is alive; waiting ${restore_switch_delay_seconds}s before LAN intercept restore"
    sleep "$restore_switch_delay_seconds"
    if transport_alive; then
      enable_intercept_rule
    else
      log "transport ${transport_tag} changed state during restore delay; leaving LAN intercept unchanged"
    fi
  else
    log "transport ${transport_tag} is alive and LAN intercept rule ${rule_section} is enabled"
  fi
  exit 0
fi

if transport_dead; then
  if [ "$disable_intercept_when_dead" != "true" ]; then
    log "transport ${transport_tag} is dead; intercept disable is disabled by model"
    exit 0
  fi

  if ! intercept_disabled; then
    log "transport ${transport_tag} is dead; waiting ${switch_delay_seconds}s before LAN intercept disable"
    sleep "$switch_delay_seconds"
    if transport_dead; then
      disable_intercept_rule
    else
      log "transport ${transport_tag} recovered during disable delay; leaving LAN intercept unchanged"
    fi
  else
    log "transport ${transport_tag} is dead and LAN intercept rule ${rule_section} is disabled"
  fi
  exit 0
fi

log "transport ${transport_tag} state is inconclusive; leaving LAN intercept rule ${rule_section} unchanged"
